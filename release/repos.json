        "ruoom",
        "scripts",
        "security",
        "static",
        "templates",
        "tests",
        "manage.py",
        "README.md",
        "LICENSE",
        "requirements.txt",
        "requirements-test.txt",
        "pytest.ini",
        ".coveragerc",
        "TESTING.md"
      ],
      "exclude": [
        ".git",
        ".github",
        ".pytest_cache",
        ".venv",
        ".vscode",
        "media",
        "plugins",
        "secret.key"
      ]
    }
  },

    "version": "1.0.0",
    "repo": "https://github.com/ruoom/ruoom-core",
    "test_command": "powershell -ExecutionPolicy Bypass -File scripts/run_tests.ps1 tests/smoke -q",
    "dependencies": {
      "required": [],
      "optional": []

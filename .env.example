# Copy this file to .env and replace deployment-specific values.
DEBUG=true
SECRET_KEY=replace-with-a-long-random-stable-secret
DATABASE_URL=postgresql://ruoom_admin:password@localhost:5432/Ruoom

# Enable the plugins installed in this deployment.
RUOOM_PLUGINS=

# Business 1's public URL. This is registered after migrations by:
# python manage.py bootstrap_business_domain
RUOOM_BUSINESS_1_URL=https://your-domain.example

# Railway's public domain is automatically trusted for CSRF requests.
RAILWAY_PUBLIC_DOMAIN=
# Optional comma-separated additional trusted origins.
# CSRF_TRUSTED_ORIGINS=https://your-custom-domain.example

# Set STORAGE=S3 to use an S3-compatible bucket for static files and uploads.
# Leave it blank for local filesystem development.
STORAGE=
AWS_S3_BUCKET_NAME=
AWS_ENDPOINT_URL=https://storage.railway.app
AWS_S3_URL_STYLE=virtual
AWS_DEFAULT_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional custom public/CDN domain. Leave blank for private buckets.
AWS_S3_CUSTOM_DOMAIN=

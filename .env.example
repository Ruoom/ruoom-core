# Copy this file to .env and replace deployment-specific values.
DEBUG=true
SECRET_KEY=replace-with-a-long-random-stable-secret
DATABASE_URL=postgresql://ruoom_admin:password@localhost:5432/Ruoom

# Enable the plugins installed in this deployment.
RUOOM_PLUGINS=payment,digitalproducts

# Business 1's public URL. This is registered after migrations by:
# python manage.py bootstrap_business_domain
RUOOM_BUSINESS_1_URL=https://your-domain.example
